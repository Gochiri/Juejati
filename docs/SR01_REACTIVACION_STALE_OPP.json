{
  "name": "[AI] Reactivación Stale Opportunities - WhatsApp",
  "description": "Secuencia automática de reactivación de leads estancados con 3 mensajes progresivos via WhatsApp. Detecta oportunidades sin actividad por 7+ días y envía seguimiento personalizado.",
  "trigger": {
    "type": "stale_opportunities",
    "name": "Detectar Estancados 7 días",
    "filters": {
      "duration_days": 7,
      "pipeline_id": "tDFS4eZP5Rliei09iGIK",
      "pipeline_name": "01 - Compradores - Seguimiento IA",
      "stage_id": "6a4a44b3-2b0c-4aad-a00d-f62276fc4e0d",
      "stage_name": "En seguimiento"
    }
  },
  "actions": [
    {
      "step": 1,
      "type": "condition",
      "name": "Verificar Tags de Exclusión",
      "if": {
        "operator": "OR",
        "conditions": [
          {
            "field": "contact.tags",
            "operator": "contains",
            "value": "detener ia"
          },
          {
            "field": "contact.tags",
            "operator": "contains",
            "value": "detener_ia"
          },
          {
            "field": "contact.tags",
            "operator": "contains",
            "value": "stop bot"
          },
          {
            "field": "contact.tags",
            "operator": "contains",
            "value": "[whatsapp] - contact is not registered"
          }
        ]
      },
      "then": {
        "action": "end_workflow",
        "note": "Lead excluido por tags de exclusión"
      },
      "else": {
        "action": "continue"
      }
    },
    {
      "step": 2,
      "type": "condition",
      "name": "Verificar WhatsApp Válido",
      "if": {
        "field": "contact.phone",
        "operator": "is_empty"
      },
      "then": {
        "action": "end_workflow",
        "note": "Lead sin WhatsApp válido"
      },
      "else": {
        "action": "continue"
      }
    },
    {
      "step": 3,
      "type": "condition",
      "name": "Verificar si ya está en reactivación",
      "if": {
        "field": "contact.tags",
        "operator": "contains",
        "value": "oportunidad estancada 7 dias"
      },
      "then": {
        "action": "end_workflow",
        "note": "Lead ya está en proceso de reactivación (evitar duplicados)"
      },
      "else": {
        "action": "continue"
      }
    },
    {
      "step": 4,
      "type": "add_tag",
      "name": "Marcar como Estancado",
      "tag_name": "oportunidad estancada 7 dias",
      "tag_id": "h77DAbGrkv1BS4ieCUD2"
    },
    {
      "step": 5,
      "type": "update_contact",
      "name": "Actualizar Fecha Primer Contacto",
      "field": "fecha_primer_contacto",
      "field_id": "nmjHXLuEaaidNamLXedw",
      "value": "{{current_date}}"
    },
    {
      "step": 6,
      "type": "create_note",
      "name": "Nota: Lead Detectado como Estancado",
      "content": "🤖 [STALE OPP] Lead detectado como estancado automáticamente por GHL.\nSin actividad desde hace 7 días.\nSistema iniciará secuencia de reactivación."
    },
    {
      "step": 7,
      "type": "wait_until",
      "name": "Verificar Horario de Envío",
      "conditions": {
        "time_between": {
          "start": "09:00",
          "end": "20:00"
        },
        "days": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"]
      }
    },
    {
      "step": 8,
      "type": "send_whatsapp",
      "name": "MENSAJE 1: Reactivación Inicial",
      "message": "Hola {{contact.first_name}}! 👋\n\nSoy el asistente de Juejati Brokers. Hace unos días estuvimos conversando sobre tu búsqueda de {{contact.tipo_de_propiedad_2}} en {{contact.zona}}.\n\n¿Seguís buscando? Tenemos propiedades nuevas que podrían interesarte 🏡\n\nTe comparto algunas opciones que se ajustan a lo que me comentaste:\n\n📍 [Propiedades dinámicas desde Tokko API]\n\n¿Alguna te llama la atención?",
      "from_number": "{{business_whatsapp_number}}",
      "variables": [
        "contact.first_name",
        "contact.tipo_de_propiedad_2",
        "contact.zona"
      ]
    },
    {
      "step": 9,
      "type": "add_tag",
      "name": "Tag: Búsqueda Activa",
      "tag_name": "busqueda tokko",
      "tag_id": "WSF3lp2CWeD8DVuJ3osU"
    },
    {
      "step": 10,
      "type": "wait",
      "name": "Esperar Respuesta (48h)",
      "duration": "48 hours",
      "until_reply": true,
      "note": "Si responde antes de 48h, workflow termina automáticamente"
    },
    {
      "step": 11,
      "type": "condition",
      "name": "DECISIÓN 1: ¿Respondió?",
      "if": {
        "field": "contact.last_inbound_message",
        "operator": "received_after",
        "value": "step_8"
      },
      "then": {
        "actions": [
          {
            "type": "remove_tag",
            "tag_name": "oportunidad estancada 7 dias"
          },
          {
            "type": "create_note",
            "content": "✅ REACTIVADO - Respondió al mensaje 1\nFecha: {{current_date}}\nHora: {{current_time}}"
          },
          {
            "type": "end_workflow"
          }
        ]
      },
      "else": {
        "action": "continue"
      }
    },
    {
      "step": 12,
      "type": "send_whatsapp",
      "name": "MENSAJE 2: Follow-up",
      "message": "{{contact.first_name}}, quería seguir ayudándote con tu búsqueda 🔍\n\nVi que te interesan {{contact.tipo_de_propiedad_2}}s en zona {{contact.zona}}, con presupuesto aproximado de {{contact.presupuesto_ia}} USD.\n\nEncontré estas opciones que coinciden:\n\n📍 Opción 1: [Título]\n💰 [Precio]\n📏 [M2]\n🔗 [Link]\n\n¿Te gustaría más info de alguna? ¿O cambió algo en tu búsqueda?",
      "from_number": "{{business_whatsapp_number}}",
      "variables": [
        "contact.first_name",
        "contact.tipo_de_propiedad_2",
        "contact.zona",
        "contact.presupuesto_ia"
      ]
    },
    {
      "step": 13,
      "type": "create_note",
      "name": "Nota: Mensaje 2 Enviado",
      "content": "🤖 Mensaje 2 de reactivación enviado\nFecha: {{current_date}}\nSin respuesta al mensaje 1."
    },
    {
      "step": 14,
      "type": "wait",
      "name": "Esperar Respuesta (72h)",
      "duration": "72 hours",
      "until_reply": true
    },
    {
      "step": 15,
      "type": "condition",
      "name": "DECISIÓN 2: ¿Respondió?",
      "if": {
        "field": "contact.last_inbound_message",
        "operator": "received_after",
        "value": "step_12"
      },
      "then": {
        "actions": [
          {
            "type": "remove_tag",
            "tag_name": "oportunidad estancada 7 dias"
          },
          {
            "type": "create_note",
            "content": "✅ REACTIVADO - Respondió al mensaje 2\nFecha: {{current_date}}\nHora: {{current_time}}"
          },
          {
            "type": "end_workflow"
          }
        ]
      },
      "else": {
        "action": "continue"
      }
    },
    {
      "step": 16,
      "type": "send_whatsapp",
      "name": "MENSAJE 3: Última Oportunidad",
      "message": "Hola {{contact.first_name}}! 👋\n\nQuiero asegurarme de que estés recibiendo la mejor atención posible.\n\nEntiendo que quizás tu búsqueda cambió o preferís que te contacte uno de nuestros asesores directamente.\n\n¿Seguís interesado/a en encontrar {{contact.tipo_de_propiedad_2}} en {{contact.zona}}?\n\nSi preferís, puedo conectarte con {{contact.asesor}} para que te asesore personalmente 🤝\n\nSolo respondeme:\n1️⃣ \"SEGUIR\" si querés que siga buscando\n2️⃣ \"ASESOR\" si preferís hablar con un humano\n3️⃣ \"PAUSA\" si querés pausar tu búsqueda",
      "from_number": "{{business_whatsapp_number}}",
      "variables": [
        "contact.first_name",
        "contact.tipo_de_propiedad_2",
        "contact.zona",
        "contact.asesor"
      ]
    },
    {
      "step": 17,
      "type": "create_note",
      "name": "Nota: Mensaje 3 Enviado",
      "content": "🤖 Mensaje 3 enviado - Última oportunidad\nFecha: {{current_date}}\nSin respuesta a mensaje 1 y 2."
    },
    {
      "step": 18,
      "type": "wait",
      "name": "Esperar Respuesta Final (48h)",
      "duration": "48 hours",
      "until_reply": true
    },
    {
      "step": 19,
      "type": "condition",
      "name": "DECISIÓN 3: ¿Respondió?",
      "if": {
        "field": "contact.last_inbound_message",
        "operator": "received_after",
        "value": "step_16"
      },
      "then": {
        "actions": [
          {
            "type": "remove_tag",
            "tag_name": "oportunidad estancada 7 dias"
          },
          {
            "type": "create_note",
            "content": "✅ REACTIVADO - Respondió al mensaje 3\nFecha: {{current_date}}\nHora: {{current_time}}"
          },
          {
            "type": "end_workflow"
          }
        ]
      },
      "else": {
        "actions": [
          {
            "type": "trigger_workflow",
            "workflow_name": "[HANDOFF] Escalamiento Stale a Agente",
            "workflow_id": "SH01",
            "note": "No respondió a ninguno de los 3 mensajes - Escalando a humano"
          }
        ]
      }
    }
  ],
  "metadata": {
    "version": "2.0",
    "created_date": "2026-01-02",
    "author": "German",
    "client": "Juejati Brokers",
    "location_id": "WWrBqekGJCsCmSSvPzEf",
    "estimated_duration": "7 días (máximo)",
    "total_messages": 3,
    "wait_times": ["48h", "72h", "48h"],
    "total_time_if_no_response": "168 horas (7 días)"
  },
  "notes": {
    "important": [
      "Este workflow usa el trigger NATIVO 'Stale Opportunities' de GHL",
      "No requiere workflow detector separado (SD01)",
      "Los mensajes incluyen variables dinámicas que deben existir en GHL",
      "El workflow termina automáticamente si el lead responde en cualquier momento",
      "Si no hay respuesta después de 3 mensajes, se dispara SH01 (Handoff)"
    ],
    "custom_fields_required": [
      "contact.first_name",
      "contact.tipo_de_propiedad_2",
      "contact.zona",
      "contact.presupuesto_ia",
      "contact.asesor",
      "contact.fecha_primer_contacto"
    ],
    "tags_required": [
      "oportunidad estancada 7 dias (h77DAbGrkv1BS4ieCUD2)",
      "busqueda tokko (WSF3lp2CWeD8DVuJ3osU)",
      "detener ia (GxSwNeDfHCo3LIVQ0f7C)",
      "detener_ia (R9w6ZQUlQ8RYhtByBzpz)",
      "stop bot (e4leD0HHY7wQ77DuPVxO)"
    ],
    "pipeline_config": {
      "pipeline_id": "tDFS4eZP5Rliei09iGIK",
      "pipeline_name": "01 - Compradores - Seguimiento IA",
      "stage_id": "6a4a44b3-2b0c-4aad-a00d-f62276fc4e0d",
      "stage_name": "En seguimiento"
    }
  }
}
