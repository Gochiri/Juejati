# PORT donde corre el servidor (default: 4000)
PORT=4000

# OpenAI
OPENAI_API_KEY=sk-...

# GoHighLevel API Key (Settings → API Keys en tu cuenta GHL)
GHL_API_KEY=eyJhb...

# PostgreSQL / Supabase connection string
# Ejemplo local (Swarm):  postgresql://user:password@postgres:5432/juejati
# Ejemplo Supabase cloud: postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# URL interna del scraper en Swarm (no cambiar si el servicio se llama zonaprop-scraper)
SCRAPER_API_URL=http://zonaprop-scraper:3000/api/search

# Tokko Broker API Key (se usa para sincronizar propiedades)
TOKKO_API_KEY=your-tokko-api-key

# Cron de seguimiento de leads
# FOLLOWUP_ENABLED: "true" activa el cron automático (el endpoint manual funciona igual)
FOLLOWUP_ENABLED=false
FOLLOWUP_INTERVAL_HOURS=3      # cada cuántas horas corre el cron
FOLLOWUP_SILENCE_HOURS=48     # horas sin respuesta antes de seguir a un lead
FOLLOWUP_MAX_ATTEMPTS=3       # máximo de follow-ups por lead
FOLLOWUP_MAX_AGE_DAYS=30      # no seguir conversaciones más viejas que esto
FOLLOWUP_MAX_ANALYSES=40      # tope de análisis IA por corrida
